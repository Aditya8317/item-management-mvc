<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Item System</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css" />
    <link href="~/Content/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Item")">ItemManager</a>
            <div class="collapse navbar-collapse">
                @if (Session["UserId"] != null)
                {
                    <ul class="navbar-nav mr-auto">
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Item")">Items</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("ProcessedItems", "Process")">Processed</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("TreeView", "Process")">Hierarchy</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item"><span class="nav-link text-white">@Session["UserEmail"]</span></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Logout", "Login")">Logout</a></li>
                    </ul>
                }
            </div>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="~/Scripts/tree.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
