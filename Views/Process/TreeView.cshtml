@model List<Round.Models.Item>
@{
    ViewBag.Title = "Tree View";
}

<div class="page-header">
    <h2><i class="fas fa-sitemap"></i> Item Hierarchy Tree</h2>
    <a href="@Url.Action("Index", "Item")" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Items
    </a>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-project-diagram"></i> Parent → Child → Sub-Child Structure
        <span class="float-right" style="font-size: 0.85rem; color: var(--text-muted);">
            Click on items with children to expand/collapse
        </span>
    </div>
    <div class="card-body tree-container">
        @if (Model != null && Model.Count > 0)
        {
            <div class="tree-view">
                <ul>
                    @foreach (var rootItem in Model)
                    {
                        @RenderTreeNode(rootItem)
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-sitemap"></i>
                <h4>No Items in Tree</h4>
                <p>Add items and process them to build the hierarchy tree.</p>
                <a href="@Url.Action("Create", "Item")" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Add Item
                </a>
            </div>
        }
    </div>
</div>

@* Recursive helper to render tree nodes *@
@helper RenderTreeNode(Round.Models.Item item)
{
    <li>
        <div class="tree-node @(item.Children.Count > 0 ? "tree-toggle" : "")">
            <span class="node-icon">
                @if (item.Children.Count > 0)
                {
                    <i class="fas fa-folder-open"></i>
                }
                else
                {
                    <i class="fas fa-file"></i>
                }
            </span>
            <span class="node-name">@item.ItemName</span>
            <span class="node-weight">
                <i class="fas fa-weight-hanging"></i> @item.Weight.ToString("F2")
            </span>
            <span class="node-status">
                @if (item.IsProcessed)
                {
                    <span class="badge-processed" style="font-size: 0.7rem;">
                        <i class="fas fa-check"></i> Processed
                    </span>
                }
                else
                {
                    <span class="badge-pending" style="font-size: 0.7rem;">
                        <i class="fas fa-clock"></i> Pending
                    </span>
                }
            </span>
        </div>
        @if (item.Children.Count > 0)
        {
            <ul>
                @foreach (var child in item.Children)
                {
                    @RenderTreeNode(child)
                }
            </ul>
        }
    </li>
}
