@model Round.Models.ProcessItemViewModel
@{
    ViewBag.Title = "Process Item";
}

<div class="page-header">
    <h2><i class="fas fa-cogs"></i> Process Item</h2>
    <a href="@Url.Action("Index", "Item")" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Items
    </a>
</div>

<div class="row">
    <!-- Weight Information Panel -->
    <div class="col-md-4">
        <div class="card" style="position: sticky; top: 1rem;">
            <div class="card-header">
                <i class="fas fa-weight-hanging"></i> Weight Summary
            </div>
            <div class="card-body">
                <div class="weight-info" style="margin-bottom: 1rem;">
                    <div class="weight-label">Parent Item</div>
                    <div class="weight-value" style="font-size: 1.1rem; color: var(--text-primary);">
                        @Model.ParentItemName
                    </div>
                </div>
                <div class="weight-info" style="margin-bottom: 1rem;">
                    <div class="weight-label">Parent Weight</div>
                    <div class="weight-value">@Model.ParentWeight.ToString("F2")</div>
                </div>
                <div class="weight-info" style="margin-bottom: 1rem;">
                    <div class="weight-label">Existing Child Weight</div>
                    <div class="weight-value" style="color: var(--warning);">
                        @Model.ExistingChildWeightSum.ToString("F2")
                    </div>
                </div>
                <div class="weight-info" style="margin-bottom: 1rem;">
                    <div class="weight-label">New Child Weight</div>
                    <div class="weight-value" style="color: var(--accent-light);">
                        <span id="newChildWeightDisplay">0.00</span>
                    </div>
                </div>
                <div class="weight-info" style="margin-bottom: 1rem;">
                    <div class="weight-label">Total Used</div>
                    <div class="weight-value" style="color: var(--text-primary);">
                        <span id="totalWeightDisplay">@Model.ExistingChildWeightSum.ToString("F2")</span>
                    </div>
                </div>
                <hr style="border-color: var(--border-color);" />
                <div class="weight-info">
                    <div class="weight-label">Remaining Capacity</div>
                    <div class="weight-value weight-remaining">
                        <span id="remainingWeightDisplay">@Model.RemainingWeight.ToString("F2")</span>
                    </div>
                </div>
                <div id="weightWarning" class="alert alert-danger" style="display: none; margin-top: 1rem; font-size: 0.85rem;">
                    <i class="fas fa-exclamation-triangle"></i> Total child weight exceeds parent weight!
                </div>
            </div>
        </div>

        <!-- Existing Children -->
        @if (Model.ExistingChildren != null && Model.ExistingChildren.Count > 0)
        {
            <div class="card" style="margin-top: 1rem;">
                <div class="card-header">
                    <i class="fas fa-sitemap"></i> Existing Children (@Model.ExistingChildren.Count)
                </div>
                <div class="card-body" style="padding: 0;">
                    <table class="table" style="margin: 0;">
                        @foreach (var child in Model.ExistingChildren)
                        {
                            <tr>
                                <td>@child.ItemName</td>
                                <td style="color: var(--accent-light); font-weight: 600;">@child.Weight.ToString("F2")</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- Child Items Form -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-plus-circle"></i> Add Child Items
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Process", "Process", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("ParentItemId", Model.ParentItemId)
                    <input type="hidden" id="parentWeight" value="@Model.ParentWeight" />
                    <input type="hidden" id="existingChildWeight" value="@Model.ExistingChildWeightSum" />

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div id="childItemsContainer">
                        @if (Model.ChildItems != null)
                        {
                            for (int i = 0; i < Model.ChildItems.Count; i++)
                            {
                                <div class="child-item-row" data-index="@i">
                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="form-group">
                                                <label>Item Name</label>
                                                <input type="text" name="ChildItems[@i].ItemName"
                                                       class="form-control"
                                                       placeholder="Enter child item name"
                                                       value="@(Model.ChildItems[i].ItemName)" required />
                                                @Html.ValidationMessage("ChildItems[" + i + "].ItemName")
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Weight</label>
                                                <input type="number" name="ChildItems[@i].Weight"
                                                       class="form-control child-weight"
                                                       placeholder="Enter weight"
                                                       value="@(Model.ChildItems[i].Weight > 0 ? Model.ChildItems[i].Weight.ToString() : "")"
                                                       min="0.01" step="0.01" required />
                                                @Html.ValidationMessage("ChildItems[" + i + "].Weight")
                                            </div>
                                        </div>
                                        <div class="col-md-3 d-flex align-items-end">
                                            <div class="form-group">
                                                @if (i > 0)
                                                {
                                                    <button type="button" class="btn btn-danger btn-sm remove-child">
                                                        <i class="fas fa-trash"></i> Remove
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div style="margin-top: 1rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
                        <button type="button" id="addChildItem" class="btn btn-secondary">
                            <i class="fas fa-plus"></i> Add Another Child
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check-circle"></i> Process Item
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
